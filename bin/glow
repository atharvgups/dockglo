#!/usr/bin/env bash
case "$1" in
  apply) DG_STYLE=${DG_STYLE:-score}  exec "$PWD/mac/reorder_and_apply.sh" apply ;;
  rainbow) DG_STYLE=rainbow          exec "$PWD/mac/reorder_and_apply.sh" apply ;;
  undo)  exec "$PWD/mac/reorder_and_apply.sh" undo ;;
  glow|"")  ./mac/reorder_and_apply.sh apply; sleep 2; ./mac/reorder_and_apply.sh undo ;;
  *) echo "usage: glow [apply|rainbow|undo|glow]"; exit 1 ;;
esac
